{
  "app_name": "DMS Implementing Agent 2.0",
  "version": "1.9",
  "scope": "Static UI shell, source document session inventory, controlled prompt generation, browser-based session report export and GitHub Pages deployment readiness",
  "architecture": "Markdown-first controlled prompt assistant",
  "authoritative_data": {
    "agent_registry": "../engine/agent_registry.json",
    "output_registry": "../engine/output_registry.json",
    "template_manifest": "../engine/template_manifest.json",
    "agent_definitions": [
      "../knowledge_base/agents/proposal_preparation_agent.json",
      "../knowledge_base/agents/project_governance_agent.json",
      "../knowledge_base/agents/document_review_agent.json",
      "../knowledge_base/agents/workflow_agent.json"
    ]
  },
  "v1_restrictions": {
    "backend_active": false,
    "docx_generation_active": false,
    "database_active": false,
    "automatic_document_generation_active": false
  },
  "fallback_configuration": {
    "enabled_for_static_file_testing": true,
    "non_authoritative": true,
    "message": "Fallback configuration loaded. Repository JSON not available. Non-authoritative; use only for local UI testing."
  },
  "source_document_inventory": {
    "storage": "browser memory only",
    "file_upload_active": false,
    "file_parsing_active": false,
    "permanent_knowledge_base_update": false
  }
}
