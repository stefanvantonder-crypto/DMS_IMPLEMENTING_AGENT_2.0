  "constraints": [
    "Use session documents only for the current session.",
    "Do not permanently update the knowledge base from session documents.",
    "Generate selected outputs only.",
    "Do not generate unselected outputs.",
    "Do not invent facts, dates, names, prices, certifications or references.",
    "Mark missing information as \"To be confirmed\".",
    "Use formal public-sector consulting language.",
    "Use Markdown-first output structure in Version 1.x.",
    "Do not create DOCX outputs in Version 1.x.",
    "Governance outputs must be controlled, auditable and implementation-ready.",
    "Use approved proposal, TOR, DMS documentation, architecture documentation, client requirements and policies where provided.",
    "Include governance, scope, roles, responsibilities, deliverables, milestones, risks, assumptions, dependencies, quality controls and sign-off sections where relevant.",
    "Do not copy client-specific details from examples unless they apply to the current session.",
    "Missing project-specific details must be marked \"To be confirmed\"."
  ],
  "validation_rules": [
    "Warn if Approved proposal is missing.",
    "Warn if Client TOR is missing.",
    "Warn if DMS system documentation is missing.",
    "Warn if DMS architecture documentation is missing.",
    "Warn if Project Charter is selected but no project charter example is provided.",
    "Warn if testing outputs are selected but no testing requirements are provided.",
    "Warn if policy-heavy outputs are selected but no client policies and procedures are provided."
  ],
  "document_classification_guidance": [
    "Classify signed or final proposal material as Approved proposal.",
    "Classify implementation terms, bid requirements and client project instructions as Client TOR.",
    "Classify manuals, module descriptions and user guidance as DMS system documentation.",
    "Classify system diagrams, architecture packs and technical platform documents as DMS architecture documentation.",
    "Classify governance examples carefully and do not copy client-specific details unless applicable to the current session.",
    "Classify policies, SOPs and governance rules as Client policies and procedures."
  ],
  "missing_information_rule": "Mark missing information as To be confirmed."
}
